# Copie para .env.production e ajuste (não commite .env.production).
# Uso: docker compose -f docker-compose.prod.yml --env-file .env.production up -d

# --- Banco (valores iguais ao serviço db no compose) ---
POSTGRES_USER=garantias
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=garantias

# DATABASE_URL com senha forte ([ ] ; @ # etc.) quebra o parser se não for codificada.
# Com POSTGRES_PASSWORD definido, o Django usa POSTGRES_* para montar a URL (DATABASE_URL vira fallback).
# DATABASE_URL=

# Se preferir URL única, codifique a senha (ex.: @ → %40):
# DATABASE_URL=postgres://garantias:SENHA_CODIFICADA@db:5432/garantias

# Se mudar só POSTGRES_PASSWORD depois que o Postgres já subiu: o volume pgdata_prod guarda a senha
# antiga. Ou recrie o volume (apaga dados): docker compose ... down -v, depois up de novo.

# --- Django ---
DJANGO_SECRET_KEY=gere-uma-chave-longa-e-aleatoria
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=seu-dominio.com.br,www.seu-dominio.com.br

# --- API (origens exatas, com esquema https://) ---
CORS_ALLOWED_ORIGINS=https://seu-dominio.com.br

# --- Opcional ---
# WEB_PORT=8000
# GARANTIAS_IMAGE=emersonlgregorio/garantias:latest
# GUNICORN_WORKERS=3
# GUNICORN_TIMEOUT=120

# --- Mapas ---
MAP_TILE_URL=https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}
MAP_TILE_ATTRIBUTION=Tiles &copy; Esri — Source: Esri, Maxar, Earthstar Geographics, and the GIS User Community
MAP_TILE_MAX_ZOOM=19
MAP_LABELS_TILE_URL=https://server.arcgisonline.com/ArcGIS/rest/services/Reference/World_Boundaries_and_Places/MapServer/tile/{z}/{y}/{x}
MAP_LABELS_ATTRIBUTION=&copy; Esri
MAP_LABELS_OPACITY=1.0
